{
  "name": "hsp-fo-workspace",
  "version": "0.23.1",
  "description": "hsp-fo-workspace for Handschriftenportal",
  "files": [
    "dist/",
    "declaration/",
    "types.ts"
  ],
  "scripts": {
    "clean": "shx rm -rf ./node_modules ./dist ./test-reports ./target ./declaration *.tgz",
    "lint": "eslint './{src,test}/**/*'",
    "test": "jest --clearCache && jest",
    "test:light": "jest --clearCache && jest --coverage=false",
    "build:dev": "webpack --mode=development --watch",
    "build": "webpack --mode=production && tsc --project tsconfig.declaration.json && webpack --mode=production --config webpack.config.standalone.js",
    "start": "shx ln -sf ../index.html dist/index.html && http-server dist",
    "deb": "echo not in use",
    "version": "echo $npm_package_version | tr -d '\n'",
    "artefactid": "echo $npm_package_name | tr -d '\n'"
  },
  "license": "MIT",
  "dependencies": {
    "hsp-web-module": "1.13.1"
  },
  "devDependencies": {
    "@material-ui/core": "^4.11.3",
    "@testing-library/react": "^11.2.5",
    "@types/css-mediaquery": "^0.1.0",
    "@types/jest": "^26.0.20",
    "@types/react": "^17.0.3",
    "@types/react-dom": "^17.0.2",
    "@types/react-redux": "^7.1.16",
    "@types/react-router-dom": "^5.1.7",
    "@typescript-eslint/eslint-plugin": "^4.17.0",
    "@typescript-eslint/parser": "^4.17.0",
    "clean-webpack-plugin": "^3.0.0",
    "copy-webpack-plugin": "^8.1.0",
    "css-mediaquery": "^0.1.2",
    "eslint": "^7.32.0",
    "eslint-config-standard": "^16.0.2",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.3.1",
    "eslint-plugin-react": "^7.22.0",
    "hsp-fo-mirador": "0.12.0",
    "http-server": "^13.0.2",
    "jest": "^27.2.5",
    "jest-junit": "^13.0.0",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-redux": "^7.2.2",
    "react-router-dom": "^5.2.0",
    "redux": "^4.0.5",
    "redux-devtools-extension": "^2.13.9",
    "shx": "^0.3.3",
    "ts-jest": "^27.0.5",
    "ts-loader": "^9.1.2",
    "tsconfig-paths-webpack-plugin": "^3.5.1",
    "typescript": "^4.2.3",
    "webpack": "^5.25.0",
    "webpack-cli": "^4.5.0"
  }
}
